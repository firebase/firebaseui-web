{
  "name": "@firebase-oss/ui-angular",
  "version": "7.0.0",
  "repository": "firebase/firebaseui-web",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/fesm2022/firebase-oss-ui-angular.mjs",
  "module": "./dist/fesm2022/firebase-oss-ui-angular.mjs",
  "typings": "./dist/types/firebase-oss-ui-angular.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/firebase-oss-ui-angular.d.ts",
      "default": "./dist/fesm2022/firebase-oss-ui-angular.mjs"
    }
  },
  "scripts": {
    "prepare": "pnpm run build",
    "build": "pnpm run update:version && pnpm run build:logos && ng-packagr -p ng-package.json",
    "update:version": "tsx update-version.ts",
    "build:logos": "tsx generate-logos.ts",
    "test": "jest --silent",
    "version:bump": "pnpm version patch",
    "publish:tags": "sh -c 'TAG=\"${npm_package_name}@${npm_package_version}\"; git tag --list \"$TAG\" | grep . || git tag \"$TAG\"; git push origin \"$TAG\"'",
    "publish:npm": "../../publish.sh",
    "release": "pnpm pack --pack-destination ../../releases/"
  },
  "peerDependencies": {
    "@angular/fire": "catalog:peerDependencies"
  },
  "dependencies": {
    "@firebase-oss/ui-core": "workspace:*",
    "@firebase-oss/ui-styles": "workspace:*",
    "@tanstack/angular-form": "^1.33.0",
    "nanostores": "catalog:",
    "tslib": "^2.8.1"
  },
  "sideEffects": false,
  "devDependencies": {
    "@angular-devkit/build-angular": "catalog:",
    "@angular/cli": "catalog:",
    "@angular/common": "catalog:",
    "@angular/compiler": "catalog:",
    "@angular/compiler-cli": "catalog:",
    "@angular/core": "catalog:",
    "@angular/fire": "catalog:",
    "@angular/forms": "catalog:",
    "@angular/platform-browser": "catalog:",
    "@angular/platform-browser-dynamic": "catalog:",
    "@angular/router": "catalog:",
    "@testing-library/angular": "^19.4.1",
    "@testing-library/jest-dom": "catalog:",
    "@types/jest": "^30.0.0",
    "@types/node": "catalog:",
    "firebase": "^11.10.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-preset-angular": "^16.2.0",
    "jsdom": "^29.1.1",
    "ng-packagr": "catalog:",
    "rxjs": "catalog:",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.0",
    "typescript": "catalog:",
    "whatwg-fetch": "^3.6.20",
    "zod": "catalog:",
    "zone.js": "catalog:"
  }
}