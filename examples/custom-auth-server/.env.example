# Snapchat Login Kit (from https://kit.snapchat.com/manage)
# Use the Confidential OAuth 2.0 Client ID and its Client Secret for server-side flow.
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=

# Firebase Admin: path to service account JSON, or leave unset to use
# GOOGLE_APPLICATION_CREDENTIALS / default credentials
FIREBASE_SERVICE_ACCOUNT_PATH=

# Port for this server (default 4000)
PORT=4000
